# WhatsApp Business API Configuration (Facebook/Meta)
# Get these values from your Facebook Developer Console

# Your WhatsApp Business Phone Number ID
REACT_APP_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Your WhatsApp Business API Access Token
REACT_APP_WHATSAPP_ACCESS_TOKEN=your_access_token_here

# Optional: Your Facebook App ID
REACT_APP_FACEBOOK_APP_ID=your_app_id_here

# Optional: Your Facebook App Secret (Keep this secure)
REACT_APP_FACEBOOK_APP_SECRET=your_app_secret_here

# Twilio WhatsApp API Configuration (Alternative)
# Get these values from your Twilio Console

# Your Twilio Account SID
REACT_APP_TWILIO_ACCOUNT_SID=AC9b0315dcf8280ac5c7e5630e3549b619

# Your Twilio Auth Token
REACT_APP_TWILIO_AUTH_TOKEN=b72f26708568eaa8522e874ce0b95a59

# Your Twilio WhatsApp From Number (sandbox: whatsapp:+14155238886)
REACT_APP_TWILIO_WHATSAPP_FROM=whatsapp:+14785513710

# Database Configuration
REACT_APP_MONGODB_URI=mongodb://localhost:27017/admin_dashboard

# Authentication
REACT_APP_JWT_SECRET=your-jwt-secret-here
REACT_APP_ADMIN_EMAIL=admin@example.com
REACT_APP_ADMIN_PASSWORD=admin123

# Debug Mode
REACT_APP_DEBUG_WHATSAPP=false
